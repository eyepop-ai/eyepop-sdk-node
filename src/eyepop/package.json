{
    "name": "@eyepop.ai/eyepop",
    "version": "0.22.0",
    "description": "The official Node.js / Typescript library for EyePop.ai's inference API",
    "keywords": [
        "AI",
        "CV",
        "ML",
        "EyePop"
    ],
    "author": "EyePop.ai",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/eyepop-ai/eyepop-sdk-node/issues"
    },
    "homepage": "https://github.com/eyepop-ai/eyepop-sdk-node#readme",
    "main": "./dist/eyepop.index.js",
    "module": "./dist/eyepop.index.mjs",
    "types": "./dist/eyepop.index.d.ts",
    "type": "commonjs",
    "browser": {
        "fs": false,
        "fs/promises": false,
        "undici": false,
        "ws": false
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup && webpack -ws",
        "dev": "tsup && webpack -ws; npx chokidar '*.ts' -c 'npx tsup && webpack'",
        "format": "npx prettier --write '**/*.{js,ts,jsx,tsx,json,css,md,ts}'"
    },
    "dependencies": {
        "@auth0/auth0-spa-js": "^2.1.3",
        "@types/mime-types": "^2.1.4",
        "@types/ws": "^8.5.11",
        "pino": "^8.17.2",
        "undici": "^6.3.0",
        "url-join": "^5.0.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "chokidar-cli": "^3.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "prettier": "^3.3.3"
    }
}
